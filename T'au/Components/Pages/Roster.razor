@page "/roster/{Side?}"
@rendermode InteractiveServer
@using System.Text.Json
@using Warhammer.Models
@using Warhammer.Services
@using System.IO
@using System.Text.RegularExpressions
@inject IWebHostEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject FactionStateService FactionState
@implements IDisposable



<div class="header-container">
    <div class="header-left">
        <h3>@GetPlayerLabel()</h3>
        @if (!string.IsNullOrEmpty(DetachmentName))
        {
            <div class="detachment-badge">
                <span class="text-warning">Detachment:</span>
                <span class="text-warning">@DetachmentName</span>
            </div>
        }
    </div>
    <div class="points-badge" style="color: @GetPlayerColor()">
        @CurrentPoints <span class="text-muted">/</span> @LimitPoints <small>pts</small>
    </div>
</div>

@if (DetachmentRule != null)
{
    <div class="detachment-box">
        <h5 class="text-warning"><i class="bi bi-star-fill me-2"></i>@DetachmentRule.Name</h5>
        <p class="mb-0 small text-white-50">@FormatText(DetachmentRule.Description)</p>
    </div>
}

@if (rosterData == null || isLoadingStrats)
{
    <div class="loading-state">
        <div class="spinner-border text-info" role="status"></div>
        <p>Retrieving Data & Stratagems...</p>
    </div>
}
else
{
    <div class="roster-grid">
        @{
            var unitList = GetUnits().ToList();
        }
        @for (int ui = 0; ui < unitList.Count; ui++)
        {
            var unit = unitList[ui];
            var unitKey = $"{unit.Name}_{ui}";
            var status = GetUnitStatus(unitKey);
            var maxW = GetMaxWoundsInt(unit);
            var curW = maxW - status.WoundsLost;
            <div class="datasheet @(status.BattleShocked ? "unit-shocked" : "")" id="@GetId(unit)">

                <div class="datasheet-header">
                    <div class="header-content">
                        <h2 class="unit-name">@unit.Name</h2>
                        <div class="role-icon"><i class="bi bi-crosshair"></i></div>
                    </div>
                    <div class="points-box">
                        <span class="pts-val">@GetPointCost(unit)</span>
                        <span class="pts-label">pts</span>
                    </div>
                </div>

                <!-- Unit Status Bar -->
                <div class="unit-status-bar">
                    <div class="usb-wounds">
                        <button class="usb-btn" @onclick="() => HealWound(unitKey)"
                                disabled="@(status.WoundsLost <= 0)">+</button>
                        <span class="usb-wounds-val @(curW <= 0 ? "usb-destroyed" : "")">
                            @if (curW <= 0)
                            {
                                <span>DESTROYED</span>
                            }
                            else
                            {
                                <span>@curW<span class="usb-wounds-max">/@GetMaxWoundsStr(unit) W</span></span>
                            }
                        </span>
                        <button class="usb-btn" @onclick="() => AddWound(unitKey)"
                                disabled="@(curW <= 0)">−</button>
                    </div>
                    <button class="usb-shock-btn @(status.BattleShocked ? "usb-shock-active" : "")"
                            @onclick="() => ToggleBattleShock(unitKey)">
                        @(status.BattleShocked ? "⚡ BATTLE-SHOCKED" : "Battle-Shock")
                    </button>
                </div>

                @{
                    var unitProfiles = GetAllProfilesRecursive(unit, "Unit").DistinctBy(p => p.Name).ToList();
                }
                @if (unitProfiles.Any())
                {
                    @foreach (var profile in unitProfiles)
                    {
                        @if (unitProfiles.Count > 1)
                        {
                            <div class="profile-name">@profile.Name</div>
                        }
                        <div class="stats-strip">
                            @if (profile.Characteristics != null)
                            {
                                @foreach (var stat in profile.Characteristics)
                                {
                                    <div class="stat-cell">
                                        <span class="stat-label">@stat.Name</span>
                                        <span class="stat-value">@stat.Value</span>
                                    </div>
                                }
                            }
                        </div>
                    }
                }

                @{
                    var unitStrats = GetStratagemsForUnit(unit.Name);
                    // Resolve objects
                    var resolvedStrats = unitStrats
                    .Select(name => AllStratagemsDetailed.FirstOrDefault(s => s.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
                    .OfType<StratagemModelWithDetachment>()
                    .ToList();

                    // Sort: Your Turn (Blue) -> Opponent (Red) -> Either (Green)
                    var sortedStrats = resolvedStrats
                    .OrderBy(s => GetStratSortOrder(s))
                    .ThenBy(s => s.Name)
                    .ToList();
                }

                @if (sortedStrats.Any())
                {
                    <div class="stratagem-bar">
                        <span class="strat-label">Stratagems:</span>
                        <div class="strat-list">
                            @foreach (var s in sortedStrats)
                            {
                                <button class="strat-badge @GetStratButtonClass(s)" @onclick="() => ShowStratagem(s.Name)">
                                    <span class="strat-name-text">@s.Name</span>
                                    <span class="cp-badge">@s.Cost CP</span>
                                    <div class="strat-hover-tooltip">
                                        <div class="tooltip-strat-name">@s.Name</div>
                                        <div class="tooltip-strat-meta">@s.Turn · @s.Phase · @s.Cost CP</div>
                                        <hr class="tooltip-strat-divider" />
                                        <div class="tooltip-strat-desc">@((MarkupString)FormatText(s.Description))</div>
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                }

                <div class="datasheet-body">
                    @{
                        var ranged = GetWeapons(unit, "Ranged Weapons");
                    }
                    @if (ranged.Any())
                    {
                        <div class="section-header">
                            <span><i class="bi bi-crosshair2 me-2"></i>Ranged Weapons</span>
                        </div>
                        <table class="weapon-table">
                            <thead>
                                <tr>
                                    <th style="width: 40%">Weapon</th>
                                    <th class="text-center">Range</th>
                                    <th class="text-center">A</th>
                                    <th class="text-center">BS</th>
                                    <th class="text-center">S</th>
                                    <th class="text-center">AP</th>
                                    <th class="text-center">D</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var w in ranged)
                                {
                                    <tr>
                                        <td class="weapon-name">
                                            @w.Name
                                            <div class="weapon-keywords">
                                                @foreach (var kw in ParseWeaponKeywords(GetChar(w, "Keywords")))
                                                {
                                                    @if (kw.Definition != null)
                                                    {
                                                        <span class="kw-tag-wrapper">
                                                            <span class="kw-tag kw-tag-glossary">[@kw.Raw]</span>
                                                            <div class="kw-tooltip">
                                                                <div class="kw-tooltip-title">@kw.Raw</div>
                                                                <div class="kw-tooltip-body">@kw.Definition</div>
                                                            </div>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="kw-tag">[@kw.Raw]</span>
                                                    }
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center">@GetChar(w, "Range")</td>
                                        <td class="text-center">@GetChar(w, "A")</td>
                                        <td class="text-center">@GetChar(w, "BS")</td>
                                        <td class="text-center">@GetChar(w, "S")</td>
                                        <td class="text-center">@GetChar(w, "AP")</td>
                                        <td class="text-center">@GetChar(w, "D")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @{
                        var melee = GetWeapons(unit, "Melee Weapons");
                    }
                    @if (melee.Any())
                    {
                        <div class="section-header mt-3">
                            <span><i class="bi bi-hammer me-2"></i>Melee Weapons</span>
                        </div>
                        <table class="weapon-table">
                            <thead>
                                <tr>
                                    <th style="width: 40%">Weapon</th>
                                    <th class="text-center">Range</th>
                                    <th class="text-center">A</th>
                                    <th class="text-center">WS</th>
                                    <th class="text-center">S</th>
                                    <th class="text-center">AP</th>
                                    <th class="text-center">D</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var w in melee)
                                {
                                    <tr>
                                        <td class="weapon-name">
                                            @w.Name
                                            <div class="weapon-keywords">
                                                @foreach (var kw in ParseWeaponKeywords(GetChar(w, "Keywords")))
                                                {
                                                    @if (kw.Definition != null)
                                                    {
                                                        <span class="kw-tag-wrapper">
                                                            <span class="kw-tag kw-tag-glossary">[@kw.Raw]</span>
                                                            <div class="kw-tooltip">
                                                                <div class="kw-tooltip-title">@kw.Raw</div>
                                                                <div class="kw-tooltip-body">@kw.Definition</div>
                                                            </div>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="kw-tag">[@kw.Raw]</span>
                                                    }
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center">@GetChar(w, "Range")</td>
                                        <td class="text-center">@GetChar(w, "A")</td>
                                        <td class="text-center">@GetChar(w, "WS")</td>
                                        <td class="text-center">@GetChar(w, "S")</td>
                                        <td class="text-center">@GetChar(w, "AP")</td>
                                        <td class="text-center">@GetChar(w, "D")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @{
                        var abilities = GetAbilities(unit);
                    }
                    @if (abilities.Any())
                    {
                        <div class="section-header mt-3"><span>Abilities & Rules</span></div>
                        <div class="abilities-box">
                            @foreach (var rule in abilities)
                            {
                                <div class="ability-row">
                                    <span class="ability-name">@rule.Name:</span>
                                    <span class="ability-desc">@FormatText(rule.Description)</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                @{
                    var keywords = GetKeywords(unit);
                }
                @if (keywords.Any())
                {
                    <div class="datasheet-footer">
                        <span class="footer-label">KEYWORDS:</span>
                        <div class="keyword-list">
                            @foreach (var k in keywords)
                            {
                                <span class="kw">@k</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@if (SelectedStratagem != null)
{
    <div class="modal-backdrop fade show" style="cursor:pointer"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-warning text-light" @onclick:stopPropagation="true">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-warning">@SelectedStratagem.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="badge bg-secondary">@SelectedStratagem.Type</span>
                        <span class="badge bg-danger">@SelectedStratagem.Cost CP</span>
                    </div>
                    <p><strong>WHEN:</strong> @SelectedStratagem.Turn</p>
                    <p><strong>PHASE:</strong> @SelectedStratagem.Phase</p>
                    <hr class="border-secondary" />
                    <div class="small">
                        @((MarkupString)FormatText(SelectedStratagem.Description))
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Unit status tracking ──────────────────────────────────────────────────
    private class UnitStatus
    {
        public int WoundsLost { get; set; } = 0;
        public bool BattleShocked { get; set; } = false;
    }

    private Dictionary<string, UnitStatus> _unitStates = new();

    private UnitStatus GetUnitStatus(string key)
    {
        if (!_unitStates.TryGetValue(key, out var s))
        {
            s = new UnitStatus();
            _unitStates[key] = s;
        }
        return s;
    }

    private string GetMaxWoundsStr(Selection unit)
    {
        var profile = GetAllProfilesRecursive(unit, "Unit").FirstOrDefault();
        return profile == null ? "?" : GetChar(profile, "W");
    }

    private int GetMaxWoundsInt(Selection unit)
    {
        var wStr = GetMaxWoundsStr(unit);
        return int.TryParse(wStr, out var w) ? Math.Max(1, w) : 1;
    }

    private void AddWound(string key)
    {
        var s = GetUnitStatus(key);
        var unit = FindUnit(key);
        if (unit != null)
            s.WoundsLost = Math.Min(s.WoundsLost + 1, GetMaxWoundsInt(unit));
        StateHasChanged();
    }

    private void HealWound(string key)
    {
        var s = GetUnitStatus(key);
        if (s.WoundsLost > 0) s.WoundsLost--;
        StateHasChanged();
    }

    private void ToggleBattleShock(string key)
    {
        var s = GetUnitStatus(key);
        s.BattleShocked = !s.BattleShocked;
        StateHasChanged();
    }

    private Selection? FindUnit(string key)
    {
        var units = GetUnits().ToList();
        var parts = key.Split('_');
        if (parts.Length >= 2 && int.TryParse(parts[^1], out var idx) && idx < units.Count)
            return units[idx];
        return null;
    }

    // ─────────────────────────────────────────────────────────────────────────
    [Parameter] public string? Side { get; set; }
    private RosterRoot? rosterData;
    private double CurrentPoints => rosterData?.Roster?.Costs?.FirstOrDefault(c => c.Name == "pts")?.Value ?? 0;
    private double LimitPoints => rosterData?.Roster?.CostLimits?.FirstOrDefault(c => c.Name == "pts")?.Value ?? 0;
    private string DetachmentName = "";
    private Rule? DetachmentRule;

    private List<StratagemModelWithDetachment> AllStratagemsDetailed = new();
    private Dictionary<string, List<string>> UnitStratagemMap = new();
    private bool isLoadingStrats = true;
    private StratagemModel? SelectedStratagem;

    public class StratagemModelWithDetachment : StratagemModel
    {
        public string Detachment { get; set; } = "";
    }

    // Setup Scroll Listener
    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Side)) Side = "p1";
        var fileName = GetFileName();
        var filePath = Path.Combine(Env.WebRootPath, fileName);

        rosterData = null;
        DetachmentName = "";
        DetachmentRule = null;

        try
        {
            if (File.Exists(filePath))
            {
                var jsonString = await File.ReadAllTextAsync(filePath);
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                rosterData = JsonSerializer.Deserialize<RosterRoot>(jsonString, options);
                var faction = rosterData?.Roster?.Forces?.FirstOrDefault()?.CatalogueName ?? "";
                if (!string.IsNullOrEmpty(faction))
                    FactionState.SetFaction(Side!, faction);
                FindDetachmentRules();
                await LoadStratagemDatabase();
            }
        }
        catch { }
    }

    // Scroll Logic
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await ScrollToFragment();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ScrollToFragment();
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private async Task ScrollToFragment()
    {
        var uri = new Uri(Nav.Uri);
        if (uri.Fragment.Length > 1)
        {
            var elementId = uri.Fragment.Substring(1);
            try
            {
                await Task.Delay(100);
                await JS.InvokeVoidAsync("scrollToElementId", elementId);
            }
            catch { }
        }
    }

    private async Task LoadStratagemDatabase()
    {
        var filePath = Path.Combine(Env.WebRootPath, "data", "Stratagems.json");
        if (!File.Exists(filePath)) { isLoadingStrats = false; return; }

        try
        {
            var jsonString = await File.ReadAllTextAsync(filePath);
            using var doc = JsonDocument.Parse(jsonString);
            var root = doc.RootElement;

            if (root.TryGetProperty("data", out var data))
            {
                AllStratagemsDetailed.Clear();
                if (data.TryGetProperty("stratagems", out var stratsArray))
                {
                    foreach (var s in stratsArray.EnumerateArray())
                    {
                        var strat = new StratagemModelWithDetachment
                        {
                            Name = GetProp(s, "name"),
                            Cost = GetProp(s, "cp_cost"),
                            Type = GetProp(s, "type"),
                            Turn = GetProp(s, "turn"),
                            Phase = GetProp(s, "phase"),
                            Description = GetProp(s, "description"),
                            FactionId = GetProp(s, "faction_id"),
                            Detachment = GetProp(s, "detachment")
                        };
                        AllStratagemsDetailed.Add(strat);
                    }
                }

                UnitStratagemMap.Clear();
                if (data.TryGetProperty("units", out var unitsArray))
                {
                    foreach (var u in unitsArray.EnumerateArray())
                    {
                        var uName = GetProp(u, "name");
                        var sList = GetProp(u, "stratagems");
                        if (!string.IsNullOrEmpty(uName) && !string.IsNullOrEmpty(sList))
                        {
                            var stratNames = sList.Split('|').Select(x => x.Trim()).ToList();
                            UnitStratagemMap[uName.ToLower()] = stratNames;
                        }
                    }
                }
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        isLoadingStrats = false;
    }

    private List<string> GetStratagemsForUnit(string unitName)
    {
        if (string.IsNullOrEmpty(unitName)) return new List<string>();

        List<string>? possibleStrats;
        if (!UnitStratagemMap.TryGetValue(unitName.ToLower(), out possibleStrats))
        {
            var key = UnitStratagemMap.Keys.FirstOrDefault(k => k.Contains(unitName.ToLower()) || unitName.ToLower().Contains(k));
            possibleStrats = key != null ? UnitStratagemMap[key] : new List<string>();
        }

        if (!possibleStrats.Any()) return new List<string>();

        var filteredList = new List<string>();
        foreach (var stratName in possibleStrats)
        {
            var stratObj = AllStratagemsDetailed.FirstOrDefault(s => s.Name.Equals(stratName, StringComparison.OrdinalIgnoreCase));
            if (stratObj != null)
            {
                // NO CORE
                if (string.IsNullOrEmpty(stratObj.FactionId)) continue;

                // DETACHMENT MATCH
                bool matchesDetachment = string.IsNullOrEmpty(stratObj.Detachment) ||
                                         DetachmentName.Contains(stratObj.Detachment, StringComparison.OrdinalIgnoreCase) ||
                                         stratObj.Detachment.Contains(DetachmentName, StringComparison.OrdinalIgnoreCase);

                if (matchesDetachment) filteredList.Add(stratName);
            }
        }
        return filteredList;
    }

    private int GetStratSortOrder(StratagemModelWithDetachment strat)
    {
        if (string.IsNullOrEmpty(strat.Turn)) return 3;
        var t = strat.Turn.ToLower();
        if (t.Contains("your turn") || t.Contains("your shooting") || t.Contains("your charge")) return 1;
        if (t.Contains("opponent's") || t.Contains("opponent’s")) return 2;
        return 3;
    }

    private string GetStratButtonClass(StratagemModel strat)
    {
        if (string.IsNullOrEmpty(strat.Turn)) return "strat-green";
        var t = strat.Turn.ToLower();
        if (t.Contains("your turn") || t.Contains("your shooting") || t.Contains("your charge")) return "strat-blue";
        if (t.Contains("opponent's") || t.Contains("opponent’s")) return "strat-red";
        return "strat-green";
    }

    private void FindDetachmentRules()
    {
        if (rosterData?.Roster?.Forces?.FirstOrDefault() == null) return;
        var force = rosterData.Roster.Forces.First();
        var detachmentSelection = force.Selections?.FirstOrDefault(s => s.Name == "Detachment");
        if (detachmentSelection?.Selections != null)
        {
            var chosen = detachmentSelection.Selections.FirstOrDefault();
            if (chosen != null)
            {
                DetachmentName = chosen.Name; DetachmentRule = chosen.Rules?.FirstOrDefault();
            }
        }

    }

    private string GetFileName() => Side switch
    {
        null or "" or "p1" => "p1.json",
        "p2" => "p2.json",
        _ => $"{Side}.json"
    };

    private string GetPlayerLabel()
    {
        if (string.IsNullOrEmpty(Side) || Side == "p1") return "Player 1 Army";
        if (int.TryParse(Side.TrimStart('p'), out var n)) return $"Player {n} Army";
        return $"{Side} Army";
    }

    private string GetPlayerColor() => Side switch
    {
        "p2" => "#5dade2",
        "p3" => "#2ecc71",
        "p4" => "#a855f7",
        "p5" => "#e74c3c",
        "p6" => "#f39c12",
        _    => "#d35400"
    };

    private string GetPlayerAccentColor() => Side switch
    {
        "p2" => "#2e86c1",
        "p3" => "#1e8449",
        "p4" => "#7c3aed",
        "p5" => "#c0392b",
        "p6" => "#d68910",
        _    => "#a04000"
    };

    // Utilities
    private void ShowStratagem(string stratName) => SelectedStratagem = AllStratagemsDetailed.FirstOrDefault(s => s.Name.Equals(stratName, StringComparison.OrdinalIgnoreCase));
    private void CloseModal() => SelectedStratagem = null;
    private string GetProp(JsonElement el, string prop) => el.TryGetProperty(prop, out var p) ? p.GetString() ?? "" : "";
    private IEnumerable<Selection> GetUnits() { if (rosterData?.Roster?.Forces?.FirstOrDefault() == null) return Enumerable.Empty<Selection>(); return rosterData.Roster.Forces.First().Selections?.Where(s => s.Name != "Configuration" && s.Name != "Battle Size" && s.Name != "Detachment" && s.Name != "Show/Hide Options").ToList() ?? new List<Selection>(); }
    private string GetId(Selection unit) => unit.Name?.Replace(" ", "-").Replace("'", "").Replace("’", "") ?? "unknown";
    private double GetPointCost(Selection unit) => unit.Costs?.FirstOrDefault(c => c.Name == "pts")?.Value ?? 0;
    private string GetChar(Profile p, string statName) => p.Characteristics?.FirstOrDefault(c => c.Name == statName)?.Value ?? "-";
    private List<Profile> GetAllProfilesRecursive(Selection current, string typeName) { var found = new List<Profile>(); if (current == null) return found; if (current.Profiles != null) found.AddRange(current.Profiles.Where(p => p.TypeName == typeName)); if (current.Selections != null) foreach (var child in current.Selections) found.AddRange(GetAllProfilesRecursive(child, typeName)); return found; }
    private List<Profile> GetWeapons(Selection unit, string type) => GetAllProfilesRecursive(unit, type).DistinctBy(w => w.Name).ToList();
    private Profile? GetProfileByType(Selection unit, string type) => GetAllProfilesRecursive(unit, type).FirstOrDefault();
    private List<Rule> GetAbilities(Selection unit) { var list = new List<Rule>(); var abilityProfiles = GetAllProfilesRecursive(unit, "Abilities"); foreach (var p in abilityProfiles) { var desc = p.Characteristics?.FirstOrDefault(c => c.Name == "Description")?.Value ?? ""; list.Add(new Rule { Name = p.Name, Description = desc }); } GetRulesRecursive(unit, list); return list.DistinctBy(r => r.Name).OrderBy(r => r.Name).ToList(); }
    private void GetRulesRecursive(Selection current, List<Rule> collected) { if (current == null) return; if (current.Rules != null) collected.AddRange(current.Rules); if (current.Selections != null) foreach (var child in current.Selections) GetRulesRecursive(child, collected); }
    private List<string> GetKeywords(Selection unit) => unit.Categories?.Where(c => c.Name != "Configuration" && c.Name != "Uncategorized").Select(c => c.Name).ToList() ?? new List<string>();

    // ── Weapon Keyword Glossary ───────────────────────────────────────────────
    private static readonly Dictionary<string, string> KeywordGlossary =
        new(StringComparer.OrdinalIgnoreCase)
        {
            ["ASSAULT"]           = "Can be used to make attacks even if the bearer Advanced this turn.",
            ["HEAVY"]             = "If the bearer did not move this turn, add 1 to each Hit roll made with this weapon.",
            ["RAPID FIRE"]        = "If the bearer did not move this turn, make [X] additional attacks with this weapon.",
            ["PISTOL"]            = "Can be used in Engagement Range; must target the closest eligible enemy unit.",
            ["TORRENT"]           = "Each attack made with this weapon automatically hits — no Hit roll required.",
            ["BLAST"]             = "Add 1 attack for every 5 models (rounding down) in the target unit.",
            ["LETHAL HITS"]       = "Each Critical Hit automatically wounds the target — no Wound roll required.",
            ["SUSTAINED HITS"]    = "Each Critical Hit scores [X] additional hits.",
            ["DEVASTATING WOUNDS"]= "Each Critical Wound causes mortal wounds equal to the weapon's Damage; the attack sequence then ends.",
            ["MELTA"]             = "Add [X] to the Damage characteristic when the target is within half the weapon's Range.",
            ["INDIRECT FIRE"]     = "Can target units not visible to the bearer. Attacks against non-visible units have −1 to Hit.",
            ["LANCE"]             = "If the bearer charged this turn, improve Armour Penetration by 1.",
            ["ANTI"]              = "Wound rolls of [X]+ automatically succeed against the specified keyword target.",
            ["HAZARDOUS"]         = "After shooting, roll 1D6 per Hazardous weapon fired: on a 1, the bearer's unit suffers 3 mortal wounds.",
            ["ONE SHOT"]          = "This weapon can only be used once per battle.",
            ["PRECISION"]         = "On a Critical Hit, the attack can be allocated to a CHARACTER model in the target unit.",
            ["PSYCHIC"]           = "Bearer must be a PSYKER. On an unmodified Hit roll of 6, the attack inflicts 1 additional mortal wound.",
            ["TWIN-LINKED"]       = "You may re-roll the Wound roll for each attack made with this weapon.",
            ["IGNORES COVER"]     = "Attacks made with this weapon ignore the benefits of cover.",
            ["EXTRA ATTACKS"]     = "Each time the bearer fights, make this many additional attacks with this weapon.",
        };

    private record KeywordToken(string Raw, string? Definition);

    private List<KeywordToken> ParseWeaponKeywords(string raw)
    {
        var result = new List<KeywordToken>();
        if (string.IsNullOrEmpty(raw) || raw == "-") return result;

        foreach (var part in raw.Split(',', StringSplitOptions.RemoveEmptyEntries))
        {
            var keyword = part.Trim();
            if (string.IsNullOrEmpty(keyword)) continue;

            // Strip trailing numeric suffix e.g. "Sustained Hits 1" → "Sustained Hits"
            var baseKey = Regex.Replace(keyword, @"\s+\d+[+]?\s*$", "").Trim();
            if (baseKey.StartsWith("Anti", StringComparison.OrdinalIgnoreCase))
                baseKey = "ANTI";

            KeywordGlossary.TryGetValue(baseKey, out var def);
            result.Add(new KeywordToken(keyword, def));
        }
        return result;
    }

    // ─────────────────────────────────────────────────────────────────────────
    private MarkupString FormatText(string text)
    {
        if (string.IsNullOrEmpty(text))
            return new MarkupString("");
        text = text.Replace("^^", "");
        text = Regex.Replace(text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        text = text.Replace("\n", "<br/>"); return new MarkupString(text);
    }
}


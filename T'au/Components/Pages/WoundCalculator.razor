@page "/woundcalc"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.RegularExpressions
@using Warhammer.Models
@using Warhammer.Services
@using System.IO
@inject IWebHostEnvironment Env
@inject StratagemService StratagemSvc

<div class="wc-page">

    <div class="wc-header">
        <h2 class="wc-title"><i class="bi bi-crosshair me-2"></i>WOUND CALCULATOR</h2>
        <p class="wc-subtitle">Warhammer 40,000 — 10th Edition</p>
    </div>

    @if (!AllUnits.Any())
    {
        <div class="wc-loading">
            <div class="spinner-border text-warning" role="status"></div>
            <p class="mt-2 text-muted">Loading roster data...</p>
        </div>
    }
    else
    {
        <!-- Full-width attack sequence banner -->
        @if (SelectedWeapon != null)
        {
            var bannerClass = GetResultClass(FinalSaveRoll ?? WoundRoll);
            <div class="wc-full-result @bannerClass">
                <div class="wc-fr-title">
                    <span class="wc-fr-weapon">@(GetCleanWeaponName(_selectedWeaponName ?? "Weapon"))</span>
                    @if (SelectedDefender != null)
                    {
                        <span class="wc-fr-sep">vs</span>
                        <span class="wc-fr-defender">@SelectedDefender.Unit.Name</span>
                    }
                </div>
                <div class="wc-sequence">
                    <div class="wc-seq-step">
                        <span class="wc-seq-label">
                            HIT@(NetHitMod > 0 ? " ▲" : NetHitMod < 0 ? " ▼" : "")
                        </span>
                        <span class="wc-seq-roll seq-hit">@(EffectiveHitRoll ?? "—")</span>
                    </div>
                    @if (EffectiveWoundRoll != null)
                    {
                        <span class="wc-seq-arrow">→</span>
                        <div class="wc-seq-step">
                            <span class="wc-seq-label">
                                WOUND@(NetWoundMod > 0 ? " ▲" : NetWoundMod < 0 ? " ▼" : "")
                            </span>
                            <span class="wc-seq-roll seq-wound">@EffectiveWoundRoll</span>
                        </div>
                    }
                    @if (FinalSaveRoll != null)
                    {
                        <span class="wc-seq-arrow">→</span>
                        <div class="wc-seq-step">
                            <span class="wc-seq-label">SAVE@((_hasCover || _defReduceAp || _invulnSave > 0) ? " ✦" : "")</span>
                            <span class="wc-seq-roll seq-save">@FinalSaveRoll</span>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="wc-arena">

            <!-- ── ATTACKER ───────────────────────────── -->
            <div class="wc-card">
                <div class="wc-card-header attacker-header">
                    <i class="bi bi-crosshair2"></i> ATTACKER
                    @if (SelectedAttacker != null)
                    {
                        <span class="wc-header-unit">— @SelectedAttacker.Unit.Name</span>
                        <button class="wc-info-btn" title="View Datasheet" @onclick="() => ShowUnitDetails(SelectedAttacker)" @onclick:stopPropagation="true">
                            <i class="bi bi-card-list me-1"></i> DATASHEET
                        </button>
                    }
                </div>
                <div class="wc-card-body">

                    <!-- Player filter -->
                    <div class="wc-player-filter">
                        <button class="wc-fbtn @(AttackerPlayerFilter == null ? "wc-fbtn-on" : "")"
                                @onclick="() => SetAttackerFilter(null)">All</button>
                        @foreach (var p in LoadedPlayers)
                        {
                            var active = AttackerPlayerFilter == p.Id;
                            <button class="wc-fbtn @(active ? "wc-fbtn-on" : "")"
                                    style="@(active ? $"--pbtn-color:{GetPlayerColor(p.Id)};" : "")"
                                    @onclick="() => SetAttackerFilter(p.Id)">P@(p.Index)</button>
                        }
                    </div>

                    <!-- Unit grid -->
                    <div class="wc-grid-label">Unit</div>
                    <div class="wc-unit-grid">
                        @foreach (var entry in FilteredAttackerUnits)
                        {
                            var sel = SelectedAttacker?.Key == entry.Key;
                            <div class="wc-tile @(sel ? "wc-tile-atk-on" : "")"
                                 @onclick="() => SelectAttackerUnit(entry)">
                                <div class="wc-tile-top">
                                    <i class="bi bi-person-fill wc-tile-ico"></i>
                                    <span class="wc-tile-name">@entry.Unit.Name</span>
                                </div>
                                <div class="wc-tile-foot">
                                    <span class="wc-tile-pid" style="color:@GetPlayerColor(entry.PlayerId)">P@(entry.PlayerIndex)</span>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Weapon grid (only after unit selected) -->
                    @if (AttackerWeapons.Any())
                    {
                        <div class="wc-grid-label mt-2">Weapon</div>
                        <div class="wc-weapon-grid">
                            @foreach (var w in AttackerWeapons)
                            {
                                var sel = _selectedWeaponName == w.Name;
                                var sVal = GetChar(w, "S");
                                var wt  = w.TypeName == "Ranged Weapons" ? "RNG" : "MEL";
                                <div class="wc-wtile @(sel ? "wc-tile-atk-on" : "")"
                                     @onclick="() => SelectWeapon(w)">
                                    <span class="wc-wtype @(wt == "RNG" ? "wt-rng" : "wt-mel")">@wt</span>
                                    <span class="wc-wname">@GetCleanWeaponName(w.Name)</span>
                                    <span class="wc-ws">S@(sVal)</span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Weapon stat bar -->
                    @if (SelectedWeapon != null)
                    {
                        <div class="wc-statbar atk-statbar">
                            @if (HitRoll != null)
                            {
                                <div class="wc-sb-stat">
                                    <span class="wc-sb-lbl">@(SelectedWeapon.TypeName == "Ranged Weapons" ? "BS" : "WS")</span>
                                    <span class="wc-sb-val wc-sb-hit">@HitRoll</span>
                                </div>
                                <div class="wc-sb-divider"></div>
                            }
                            @if (WeaponStrength.HasValue)
                            {
                                <div class="wc-sb-stat">
                                    <span class="wc-sb-lbl">S</span>
                                    <span class="wc-sb-val">@WeaponStrength</span>
                                </div>
                            }
                            @if (WeaponAp.HasValue)
                            {
                                <div class="wc-sb-divider"></div>
                                <div class="wc-sb-stat">
                                    <span class="wc-sb-lbl">AP</span>
                                    <span class="wc-sb-val wc-sb-ap">@WeaponAp</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(WeaponAttacks) && WeaponAttacks != "-")
                            {
                                <div class="wc-sb-divider"></div>
                                <div class="wc-sb-stat">
                                    <span class="wc-sb-lbl">A</span>
                                    <span class="wc-sb-val wc-sb-atk">@WeaponAttacks</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(SelectedWeaponMeta))
                            {
                                <span class="wc-sb-meta">@SelectedWeaponMeta</span>
                            }
                        </div>
                        @if (SelectedWeaponKeywords.Any())
                        {
                            <div class="wc-kw-row">
                                @foreach (var kw in SelectedWeaponKeywords)
                                {
                                    @if (kw.Definition != null)
                                    {
                                        <span class="kw-tag-wrapper">
                                            <span class="wc-kw-tag kw-tag-glossary">@kw.Raw</span>
                                            <div class="kw-tooltip">
                                                <div class="kw-tooltip-title">@kw.Raw</div>
                                                <div class="kw-tooltip-body">@kw.Definition</div>
                                            </div>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="wc-kw-tag">@kw.Raw</span>
                                    }
                                }
                            </div>
                        }
                    }

                    <!-- Attacker modifiers -->
                    @if (SelectedWeapon != null)
                    {
                        <div class="wc-mods-section">
                            <div class="wc-mods-label">Modifiers</div>
                            <div class="wc-mods-row">
                                <button class="wc-mod-btn @(_atkPlusOneHit ? "wc-mod-on" : "")"
                                        @onclick="() => { _atkPlusOneHit = !_atkPlusOneHit; Recalculate(); }">
                                    <i class="bi bi-arrow-up-circle"></i> +1 HIT
                                </button>
                                <button class="wc-mod-btn @(_atkPlusOneWound ? "wc-mod-on" : "")"
                                        @onclick="() => { _atkPlusOneWound = !_atkPlusOneWound; Recalculate(); }">
                                    <i class="bi bi-arrow-up-circle"></i> +1 WOUND
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Attacker Stratagems -->
                    @if (AttackerStratagems.Any())
                    {
                        <div class="wc-strat-section">
                            <div class="wc-mods-label">Stratagems</div>
                            <div class="strat-list">
                                @foreach (var s in AttackerStratagems)
                                {
                                    <button class="strat-badge @StratClass(s)" @onclick="() => ShowStratagem(s)">
                                        <span class="strat-name-text">@s.Name</span>
                                        <span class="cp-badge">@s.Cost CP</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Attacker Abilities -->
                    @if (AttackerAbilities.Any())
                    {
                        <div class="wc-mods-section">
                            <div class="wc-mods-label"><i class="bi bi-lightning-fill me-1"></i>Abilities</div>
                            <div class="wc-ability-list">
                                @foreach (var rule in AttackerAbilities)
                                {
                                    var r = rule;
                                    <span class="kw-tag-wrapper">
                                        <button class="wc-ability-btn" @onclick="() => ShowRule(r)">@r.Name</button>
                                        <div class="kw-tooltip">
                                            <div class="kw-tooltip-title">@r.Name</div>
                                            <div class="kw-tooltip-body">@((MarkupString)FormatText(r.Description))</div>
                                        </div>
                                    </span>
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>

            <!-- ── VS COL ──────────────────────────────── -->
            <div class="wc-vs-col">
                <div class="wc-vs-badge">VS</div>
                <button class="wc-swap-btn"
                        title="Swap Attacker and Defender"
                        disabled="@(SelectedAttacker == null && SelectedDefender == null)"
                        @onclick="SwapRoles">
                    <i class="bi bi-arrow-left-right"></i>
                    <span class="wc-swap-label">SWAP</span>
                </button>
                @if (EffectiveWoundRoll != null)
                {
                    <div class="wc-mini-result @GetResultClass(EffectiveWoundRoll)">
                        <div class="wc-mr-label">wound</div>
                        <div class="wc-mr-roll">@EffectiveWoundRoll</div>
                        @if (FinalSaveRoll != null)
                        {
                            <div class="wc-mr-label">save @FinalSaveRoll</div>
                        }
                    </div>
                }
                <!-- Quick reference table -->
                <div class="wc-reference">
                    <table class="wc-ref-table">
                        <tbody>
                            <tr class="@(WoundRoll == "2+" ? "wc-ref-on" : "")">
                                <td>S≥2T</td><td class="roll-2">2+</td>
                            </tr>
                            <tr class="@(WoundRoll == "3+" ? "wc-ref-on" : "")">
                                <td>S&gt;T</td><td class="roll-3">3+</td>
                            </tr>
                            <tr class="@(WoundRoll == "4+" ? "wc-ref-on" : "")">
                                <td>S=T</td><td class="roll-4">4+</td>
                            </tr>
                            <tr class="@(WoundRoll == "5+" ? "wc-ref-on" : "")">
                                <td>S&lt;T</td><td class="roll-5">5+</td>
                            </tr>
                            <tr class="@(WoundRoll == "6+" ? "wc-ref-on" : "")">
                                <td>S≤½T</td><td class="roll-6">6+</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ── DEFENDER ───────────────────────────── -->
            <div class="wc-card">
                <div class="wc-card-header defender-header">
                    <i class="bi bi-shield-fill"></i> DEFENDER
                    @if (SelectedDefender != null)
                    {
                        <span class="wc-header-unit">— @SelectedDefender.Unit.Name</span>
                        <button class="wc-info-btn" title="View Datasheet" @onclick="() => ShowUnitDetails(SelectedDefender)" @onclick:stopPropagation="true">
                            <i class="bi bi-card-list me-1"></i> DATASHEET
                        </button>
                    }
                </div>
                <div class="wc-card-body">

                    <!-- Player filter -->
                    <div class="wc-player-filter">
                        <button class="wc-fbtn @(DefenderPlayerFilter == null ? "wc-fbtn-on" : "")"
                                @onclick="() => SetDefenderFilter(null)">All</button>
                        @foreach (var p in LoadedPlayers)
                        {
                            var active = DefenderPlayerFilter == p.Id;
                            <button class="wc-fbtn @(active ? "wc-fbtn-on" : "")"
                                    style="@(active ? $"--pbtn-color:{GetPlayerColor(p.Id)};" : "")"
                                    @onclick="() => SetDefenderFilter(p.Id)">P@(p.Index)</button>
                        }
                    </div>

                    <!-- Unit grid -->
                    <div class="wc-grid-label">Unit</div>
                    <div class="wc-unit-grid">
                        @foreach (var entry in FilteredDefenderUnits)
                        {
                            var sel = SelectedDefender?.Key == entry.Key;
                            <div class="wc-tile @(sel ? "wc-tile-def-on" : "")"
                                 @onclick="() => SelectDefenderUnit(entry)">
                                <div class="wc-tile-top">
                                    <i class="bi bi-shield-fill wc-tile-ico"></i>
                                    <span class="wc-tile-name">@entry.Unit.Name</span>
                                </div>
                                <div class="wc-tile-foot">
                                    <span class="wc-tile-pid" style="color:@GetPlayerColor(entry.PlayerId)">P@(entry.PlayerIndex)</span>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Defender stat bar + cover toggle -->
                    @if (DefenderToughness.HasValue)
                    {
                        <div class="wc-statbar def-statbar">
                            <div class="wc-sb-stat">
                                <span class="wc-sb-lbl">T</span>
                                <span class="wc-sb-val">@DefenderToughness</span>
                            </div>
                            @if (DefenderSave.HasValue)
                            {
                                <div class="wc-sb-divider"></div>
                                <div class="wc-sb-stat">
                                    <span class="wc-sb-lbl">Sv</span>
                                    <span class="wc-sb-val wc-sb-sv">@(DefenderSave)@("+")</span>
                                </div>
                            }
                        </div>
                        <button class="wc-cover-btn @(_hasCover ? "wc-cover-on" : "")"
                                @onclick="ToggleCover">
                            <i class="bi @(_hasCover ? "bi-tree-fill" : "bi-tree") me-1"></i>
                            IN COVER @(_hasCover ? "(+1 Sv)" : "")
                        </button>

                        <!-- Defender modifiers -->
                        <div class="wc-mods-section">
                            <div class="wc-mods-label">Modifiers</div>
                            <div class="wc-mods-row">
                                <button class="wc-mod-btn @(_defMinusOneHit ? "wc-mod-on" : "")"
                                        @onclick="() => { _defMinusOneHit = !_defMinusOneHit; Recalculate(); }">
                                    <i class="bi bi-arrow-down-circle"></i> -1 vs HIT
                                </button>
                                <button class="wc-mod-btn @(_defMinusOneWound ? "wc-mod-on" : "")"
                                        @onclick="() => { _defMinusOneWound = !_defMinusOneWound; Recalculate(); }">
                                    <i class="bi bi-arrow-down-circle"></i> -1 vs WND
                                </button>
                                <button class="wc-mod-btn @(_defReduceAp ? "wc-mod-on" : "")"
                                        @onclick="() => { _defReduceAp = !_defReduceAp; Recalculate(); }">
                                    <i class="bi bi-shield-plus"></i> AP -1
                                </button>
                            </div>
                        </div>

                        <!-- Invulnerable save -->
                        <div class="wc-mods-section">
                            <div class="wc-mods-label">
                                Invuln Save
                                @if (_autoInvulnSave.HasValue)
                                {
                                    <span class="wc-auto-badge">auto @(_autoInvulnSave)@("+")</span>
                                }
                            </div>
                            <div class="wc-mods-row">
                                <button class="wc-fbtn @(_invulnSave == 0 ? "wc-fbtn-on" : "")"
                                        @onclick="() => { _invulnSave = 0; Recalculate(); }">None</button>
                                @foreach (var inv in new[] { 3, 4, 5, 6 })
                                {
                                    <button class="wc-fbtn @(_invulnSave == inv ? "wc-fbtn-on" : "")"
                                            style="@(_invulnSave == inv ? "--pbtn-color:#a855f7;" : "")"
                                            @onclick="() => { _invulnSave = inv; Recalculate(); }">@(inv)@("+")</button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Defender Stratagems -->
                    @if (DefenderStratagems.Any())
                    {
                        <div class="wc-strat-section">
                            <div class="wc-mods-label">Stratagems</div>
                            <div class="strat-list">
                                @foreach (var s in DefenderStratagems)
                                {
                                    <button class="strat-badge @StratClass(s)" @onclick="() => ShowStratagem(s)">
                                        <span class="strat-name-text">@s.Name</span>
                                        <span class="cp-badge">@s.Cost CP</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <!-- Defender Abilities -->
                    @if (DefenderAbilities.Any())
                    {
                        <div class="wc-mods-section">
                            <div class="wc-mods-label"><i class="bi bi-lightning-fill me-1"></i>Abilities</div>
                            <div class="wc-ability-list">
                                @foreach (var rule in DefenderAbilities)
                                {
                                    var r = rule;
                                    <span class="kw-tag-wrapper">
                                        <button class="wc-ability-btn" @onclick="() => ShowRule(r)">@r.Name</button>
                                        <div class="kw-tooltip">
                                            <div class="kw-tooltip-title">@r.Name</div>
                                            <div class="kw-tooltip-body">@((MarkupString)FormatText(r.Description))</div>
                                        </div>
                                    </span>
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>

        </div>
    }
</div>

@if (SelectedStratagem != null)
{
    <div class="modal-backdrop fade show" style="cursor:pointer"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-warning text-light" @onclick:stopPropagation="true">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-warning">@SelectedStratagem.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="badge bg-secondary">@SelectedStratagem.Type</span>
                        <span class="badge bg-danger">@SelectedStratagem.Cost CP</span>
                    </div>
                    <p><strong>WHEN:</strong> @SelectedStratagem.Turn</p>
                    <p><strong>PHASE:</strong> @SelectedStratagem.Phase</p>
                    <hr class="border-secondary" />
                    <div class="small">
                        @((MarkupString)SelectedStratagem.Description)
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (SelectedRule != null)
{
    <div class="modal-backdrop fade show" style="cursor:pointer" @onclick="CloseRuleModal"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" @onclick="CloseRuleModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary text-light" @onclick:stopPropagation="true">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" style="color:#c084fc">@SelectedRule.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseRuleModal"></button>
                </div>
                <div class="modal-body small" style="line-height:1.6">
                    @((MarkupString)FormatText(SelectedRule.Description))
                </div>
            </div>
        </div>
    </div>
}

@if (ModalUnit != null)
{
    var mu         = ModalUnit.Unit;
    var muProfiles = GetAllProfilesRecursive(mu, "Unit").DistinctBy(p => p.Name).ToList();
    var muRanged   = GetAllProfilesRecursive(mu, "Ranged Weapons").DistinctBy(w => w.Name).ToList();
    var muMelee    = GetAllProfilesRecursive(mu, "Melee Weapons").DistinctBy(w => w.Name).ToList();
    var muAbils    = GetAbilities(mu);
    var muKws      = GetKeywords(mu);
    <div class="modal-backdrop fade show" style="cursor:pointer" @onclick="CloseUnitDetails"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" @onclick="CloseUnitDetails">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content wc-ds-modal" @onclick:stopPropagation="true">

                <div class="wc-ds-header">
                    <h5 class="wc-ds-title">@mu.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseUnitDetails"></button>
                </div>

                <div class="modal-body wc-ds-body">

                    @foreach (var profile in muProfiles)
                    {
                        @if (muProfiles.Count > 1)
                        {
                            <div class="ds-profile-name">@profile.Name</div>
                        }
                        <div class="ds-stats-strip">
                            @if (profile.Characteristics != null)
                            {
                                @foreach (var stat in profile.Characteristics)
                                {
                                    <div class="ds-stat-cell">
                                        <span class="ds-stat-label">@stat.Name</span>
                                        <span class="ds-stat-value">@stat.Value</span>
                                    </div>
                                }
                            }
                        </div>
                    }

                    @if (muRanged.Any())
                    {
                        <WeaponTable Weapons="muRanged" SectionTitle="Ranged Weapons" SectionIcon="bi-crosshair2" SkillHeader="BS" />
                    }

                    @if (muMelee.Any())
                    {
                        <WeaponTable Weapons="muMelee" SectionTitle="Melee Weapons" SectionIcon="bi-hammer" SkillHeader="WS" AddTopMargin="true" />
                    }

                    @if (muAbils.Any())
                    {
                        <div class="section-header mt-2">Abilities & Rules</div>
                        <div class="abilities-box" style="padding: 10px 15px;">
                            @foreach (var rule in muAbils)
                            {
                                <div class="ability-row">
                                    <span class="ability-name">@rule.Name:</span>
                                    <span class="ability-desc">@FormatText(rule.Description)</span>
                                </div>
                            }
                        </div>
                    }

                    @if (muKws.Any())
                    {
                        <div class="datasheet-footer">
                            <span class="footer-label">KEYWORDS:</span>
                            <div class="keyword-list">
                                @foreach (var k in muKws)
                                {
                                    <span class="kw">@k</span>
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
}

@code {
    private record UnitEntry(string Key, string Label, string PlayerId, int PlayerIndex, Selection Unit, string DetachmentName);

    private List<UnitEntry> AllUnits = new();
    private List<Profile> AttackerWeapons = new();

    private string? AttackerPlayerFilter;
    private string? DefenderPlayerFilter;

    private UnitEntry? SelectedAttacker;
    private UnitEntry? SelectedDefender;
    private string? _selectedWeaponName;
    private Profile? SelectedWeapon;

    private int? WeaponStrength;
    private int? WeaponAp;
    private string? HitRoll;
    private int? DefenderToughness;
    private int? DefenderSave;
    private bool _hasCover;
    private string? WoundRoll;
    private string? FinalSaveRoll;
    private string SelectedWeaponMeta = "";
    private string? WeaponAttacks;
    private string? WeaponKeywords;
    private List<KeywordToken> SelectedWeaponKeywords = new();

    // Modifier toggles
    private bool _atkPlusOneHit;
    private bool _atkPlusOneWound;
    private bool _defMinusOneHit;
    private bool _defMinusOneWound;
    private bool _defReduceAp;
    private int  _invulnSave;       // 0 = None, else 3/4/5/6
    private int? _autoInvulnSave;   // detected from unit profile

    // Effective display rolls (post-modifier)
    private int    NetHitMod;
    private int    NetWoundMod;
    private string? EffectiveHitRoll;
    private string? EffectiveWoundRoll;

    private List<StratagemModelWithDetachment> AttackerStratagems = new();
    private List<StratagemModelWithDetachment> DefenderStratagems = new();
    private StratagemModelWithDetachment? SelectedStratagem;
    private UnitEntry? ModalUnit;
    private List<Rule> AttackerAbilities = new();
    private List<Rule> DefenderAbilities = new();
    private Rule? SelectedRule;

    private IEnumerable<(string Id, int Index)> LoadedPlayers =>
        AllUnits.Select(u => (u.PlayerId, u.PlayerIndex))
                .DistinctBy(x => x.Item1)
                .OrderBy(x => x.Item2);

    private IEnumerable<UnitEntry> FilteredAttackerUnits =>
        AttackerPlayerFilter == null
            ? AllUnits
            : AllUnits.Where(u => u.PlayerId == AttackerPlayerFilter);

    private IEnumerable<UnitEntry> FilteredDefenderUnits =>
        DefenderPlayerFilter == null
            ? AllUnits
            : AllUnits.Where(u => u.PlayerId == DefenderPlayerFilter);

    protected override async Task OnInitializedAsync()
    {
        await StratagemSvc.EnsureLoadedAsync();

        int playerIndex = 1;
        while (true)
        {
            string playerId = $"p{playerIndex}";
            var filePath = Path.Combine(Env.WebRootPath, $"{playerId}.json");
            if (!File.Exists(filePath)) break;

            try
            {
                var jsonString = await File.ReadAllTextAsync(filePath);
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var data = JsonSerializer.Deserialize<RosterRoot>(jsonString, options);
                var force = data?.Roster?.Forces?.FirstOrDefault();
                if (force == null) { playerIndex++; continue; }

                var detachment = force.Selections
                    .FirstOrDefault(s => s.Name == "Detachment")
                    ?.Selections?.FirstOrDefault()?.Name ?? "";

                var units = force.Selections
                    .Where(s => s.Name != "Configuration" &&
                                s.Name != "Battle Size" &&
                                s.Name != "Detachment" &&
                                s.Name != "Show/Hide Options")
                    .ToList();

                foreach (var unit in units.DistinctBy(u => u.Name))
                {
                    AllUnits.Add(new UnitEntry(
                        $"{playerId}_{unit.Name}",
                        unit.Name,
                        playerId,
                        playerIndex,
                        unit,
                        detachment
                    ));
                }
            }
            catch { }

            playerIndex++;
        }
    }

    private void SetAttackerFilter(string? playerId)
    {
        AttackerPlayerFilter = playerId;
        if (SelectedAttacker != null && playerId != null && SelectedAttacker.PlayerId != playerId)
            ClearAttacker();
    }

    private void SetDefenderFilter(string? playerId)
    {
        DefenderPlayerFilter = playerId;
        if (SelectedDefender != null && playerId != null && SelectedDefender.PlayerId != playerId)
            ClearDefender();
    }

    private void SelectAttackerUnit(UnitEntry entry)
    {
        if (SelectedAttacker?.Key == entry.Key) { ClearAttacker(); return; }

        SelectedAttacker = entry;
        _selectedWeaponName = null;
        SelectedWeapon = null;
        WeaponStrength = null;
        SelectedWeaponMeta = "";
        WeaponAttacks = null;
        WeaponKeywords = null;
        SelectedWeaponKeywords = new();
        _atkPlusOneHit = false;
        _atkPlusOneWound = false;
        AttackerWeapons = GetAllWeapons(entry.Unit);
        AttackerStratagems = StratagemSvc.GetStratagemsForUnit(entry.Unit.Name, entry.DetachmentName)
            .Where(s => s.Turn.Contains("your", StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Phase).ThenBy(s => s.Name)
            .ToList();
        AttackerAbilities = GetAbilities(entry.Unit);
        Recalculate();
    }

    private void SelectWeapon(Profile w)
    {
        if (_selectedWeaponName == w.Name) { ClearWeapon(); return; }

        _selectedWeaponName = w.Name;
        SelectedWeapon = w;

        var sVal = GetChar(w, "S");
        WeaponStrength = int.TryParse(sVal, out var s) ? s : null;

        var apVal = GetChar(w, "AP");
        WeaponAp = int.TryParse(apVal, out var ap) ? ap : null;

        var skillStat = w.TypeName == "Ranged Weapons" ? "BS" : "WS";
        var skillRaw  = GetChar(w, skillStat);
        if (skillRaw == "N/A" || skillRaw == "-")
        {
            HitRoll = "AUTO";
        }
        else
        {
            HitRoll = skillRaw; // stored as-is e.g. "3+"
        }

        WeaponAttacks  = GetChar(w, "A");
        WeaponKeywords = GetChar(w, "Keywords");
        SelectedWeaponKeywords = RosterHelper.ParseWeaponKeywords(WeaponKeywords ?? "");
        var range = GetChar(w, "Range");
        var dmg   = GetChar(w, "D");
        SelectedWeaponMeta = $"{range}  D:{dmg}";
        Recalculate();
    }

    private void SelectDefenderUnit(UnitEntry entry)
    {
        if (SelectedDefender?.Key == entry.Key) { ClearDefender(); return; }

        SelectedDefender = entry;
        _hasCover        = false;
        _defMinusOneHit  = false;
        _defMinusOneWound = false;
        _defReduceAp     = false;

        var unitProfile = GetAllProfilesRecursive(entry.Unit, "Unit").FirstOrDefault();
        var tVal  = GetChar(unitProfile, "T");
        var svVal = GetChar(unitProfile, "SV"); 
        DefenderToughness = int.TryParse(tVal, out var t)  ? t  : null;
        DefenderSave      = int.TryParse(svVal.TrimEnd('+'), out var sv) ? sv : null;

        _autoInvulnSave = ParseInvulnSave(entry.Unit);
        _invulnSave     = _autoInvulnSave ?? 0;

        DefenderStratagems = StratagemSvc.GetStratagemsForUnit(entry.Unit.Name, entry.DetachmentName)
            .Where(s => s.Turn.Contains("opponent", StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Phase).ThenBy(s => s.Name)
            .ToList();
        DefenderAbilities = GetAbilities(entry.Unit);

        Recalculate();
    }

    private void ClearAttacker()
    {
        SelectedAttacker = null;
        AttackerWeapons = new();
        AttackerStratagems = new();
        AttackerAbilities = new();
        ClearWeapon();
    }

    private void ClearWeapon()
    {
        SelectedWeapon = null;
        _selectedWeaponName = null;
        WeaponStrength = null;
        WeaponAp = null;
        HitRoll = null;
        SelectedWeaponMeta = "";
        WeaponAttacks = null;
        WeaponKeywords = null;
        SelectedWeaponKeywords = new();
        Recalculate();
    }

    private void ClearDefender()
    {
        SelectedDefender  = null;
        DefenderToughness = null;
        DefenderSave      = null;
        _hasCover         = false;
        _defMinusOneHit   = false;
        _defMinusOneWound = false;
        _defReduceAp      = false;
        _invulnSave       = 0;
        _autoInvulnSave   = null;
        DefenderStratagems = new();
        DefenderAbilities = new();
        Recalculate();
    }

    private void SwapRoles()
    {
        var oldAttacker       = SelectedAttacker;
        var oldDefender       = SelectedDefender;
        var oldAttackerFilter = AttackerPlayerFilter;
        var oldDefenderFilter = DefenderPlayerFilter;

        // Cross the player filters
        AttackerPlayerFilter = oldDefenderFilter;
        DefenderPlayerFilter = oldAttackerFilter;

        // Old Defender → new Attacker (weapon selection reset; user must pick one)
        SelectedAttacker    = oldDefender;
        _selectedWeaponName = null;
        SelectedWeapon      = null;
        WeaponStrength      = null;
        WeaponAp            = null;
        HitRoll             = null;
        SelectedWeaponMeta  = "";
        WeaponAttacks       = null;
        WeaponKeywords      = null;
        SelectedWeaponKeywords = new();
        _atkPlusOneHit      = false;
        _atkPlusOneWound    = false;
        AttackerWeapons     = oldDefender != null ? GetAllWeapons(oldDefender.Unit) : new();

        // Old Attacker → new Defender (re-derive T, Sv, invuln)
        SelectedDefender  = oldAttacker;
        _hasCover         = false;
        _defMinusOneHit   = false;
        _defMinusOneWound = false;
        _defReduceAp      = false;
        if (oldAttacker != null)
        {
            var unitProfile = GetAllProfilesRecursive(oldAttacker.Unit, "Unit").FirstOrDefault();
            var tVal  = GetChar(unitProfile, "T");
            var svVal = GetChar(unitProfile, "SV");
            DefenderToughness = int.TryParse(tVal, out var t) ? t : null;
            DefenderSave      = int.TryParse(svVal.TrimEnd('+'), out var sv) ? sv : null;
            _autoInvulnSave   = ParseInvulnSave(oldAttacker.Unit);
            _invulnSave       = _autoInvulnSave ?? 0;
        }
        else
        {
            DefenderToughness = null;
            DefenderSave      = null;
            _autoInvulnSave   = null;
            _invulnSave       = 0;
        }

        AttackerStratagems = SelectedAttacker != null
            ? StratagemSvc.GetStratagemsForUnit(SelectedAttacker.Unit.Name, SelectedAttacker.DetachmentName)
                .Where(s => s.Turn.Contains("your", StringComparison.OrdinalIgnoreCase))
                .OrderBy(s => s.Phase).ThenBy(s => s.Name).ToList()
            : new();
        AttackerAbilities = SelectedAttacker != null ? GetAbilities(SelectedAttacker.Unit) : new();

        DefenderStratagems = SelectedDefender != null
            ? StratagemSvc.GetStratagemsForUnit(SelectedDefender.Unit.Name, SelectedDefender.DetachmentName)
                .Where(s => s.Turn.Contains("opponent", StringComparison.OrdinalIgnoreCase))
                .OrderBy(s => s.Phase).ThenBy(s => s.Name).ToList()
            : new();
        DefenderAbilities = SelectedDefender != null ? GetAbilities(SelectedDefender.Unit) : new();

        Recalculate();
    }

    private void Recalculate()
    {
        // ── Net modifiers (10th Ed: capped at [-1, +1]) ───────────────────
        NetHitMod   = Math.Clamp((_atkPlusOneHit  ? 1 : 0) - (_defMinusOneHit   ? 1 : 0), -1, 1);
        NetWoundMod = Math.Clamp((_atkPlusOneWound ? 1 : 0) - (_defMinusOneWound ? 1 : 0), -1, 1);

        // ── Effective AP (AP reduction: makes AP less severe, floor at 0) ─
        int effectiveAp = WeaponAp.HasValue
            ? (_defReduceAp ? Math.Min(WeaponAp.Value + 1, 0) : WeaponAp.Value)
            : 0;

        // ── Base wound roll ───────────────────────────────────────────────
        if (WeaponStrength.HasValue && DefenderToughness.HasValue)
        {
            int s = WeaponStrength.Value, t = DefenderToughness.Value;
            WoundRoll = s >= t * 2 ? "2+" :
                        s > t      ? "3+" :
                        s == t     ? "4+" :
                        s * 2 <= t ? "6+" :
                                     "5+";
        }
        else { WoundRoll = null; }

        // ── Effective hit roll (with modifier) ────────────────────────────
        if (HitRoll != null && HitRoll != "AUTO")
        {
            int baseHit = ParseRollNum(HitRoll);
            int eff     = Math.Clamp(baseHit - NetHitMod, 2, 7);
            EffectiveHitRoll = eff <= 6 ? $"{eff}+" : "N/A";
        }
        else { EffectiveHitRoll = HitRoll; }

        // ── Effective wound roll (with modifier) ──────────────────────────
        if (WoundRoll != null)
        {
            int baseWound = ParseRollNum(WoundRoll);
            int eff       = Math.Clamp(baseWound - NetWoundMod, 2, 7);
            EffectiveWoundRoll = eff <= 6 ? $"{eff}+" : "N/A";
        }
        else { EffectiveWoundRoll = null; }

        // ── Final save: armour vs invuln, take the better ─────────────────
        if (DefenderSave.HasValue && WeaponAp.HasValue)
        {
            int rawArmour   = DefenderSave.Value + Math.Abs(effectiveAp);
            int adjustedArmour = rawArmour - (_hasCover ? 1 : 0);
            int armourSave  = Math.Max(adjustedArmour, DefenderSave.Value); // cover can't beat base

            int finalSaveNum;
            if (_invulnSave > 0)
                finalSaveNum = armourSave <= 6 ? Math.Min(armourSave, _invulnSave) : _invulnSave;
            else
                finalSaveNum = armourSave;

            FinalSaveRoll = finalSaveNum <= 6 ? $"{finalSaveNum}+" : "N/A";
        }
        else if (_invulnSave > 0 && WeaponAp.HasValue)
        {
            FinalSaveRoll = $"{_invulnSave}+";
        }
        else { FinalSaveRoll = null; }
    }

    private void ToggleCover() { _hasCover = !_hasCover; Recalculate(); }

    private static int ParseRollNum(string roll)
    {
        return int.TryParse(roll.TrimEnd('+'), out var n) ? n : 4;
    }

    private static string GetCleanWeaponName(string raw) => RosterHelper.GetCleanWeaponName(raw);

    private int? ParseInvulnSave(Selection unit)
    {
        // Look for a profile named "Invulnerable Save" (or containing "Invulnerable")
        var abilityProfiles = GetAllProfilesRecursive(unit, "Abilities");
        foreach (var p in abilityProfiles)
        {
            if (!p.Name.Contains("Invulnerable", StringComparison.OrdinalIgnoreCase)) continue;
            var desc = p.Characteristics?.FirstOrDefault(c => c.Name == "Description")?.Value ?? p.Name;
            var m = Regex.Match(desc, @"\b([2-6])\+");
            if (m.Success && int.TryParse(m.Groups[1].Value, out int inv)) return inv;
        }

        // Fall back: scan all rules text for "invulnerable ... X+"
        var rules = CollectRules(unit);
        foreach (var r in rules)
        {
            var text = r.Name + " " + r.Description;
            if (!text.Contains("invulnerable", StringComparison.OrdinalIgnoreCase)) continue;
            var m = Regex.Match(text, @"\b([2-6])\+");
            if (m.Success && int.TryParse(m.Groups[1].Value, out int inv)) return inv;
        }
        return null;
    }

    private List<Rule> CollectRules(Selection sel) => RosterHelper.CollectRules(sel);

    // ─────────────────────────────────────────────────────────────────────────
    private string GetResultClass(string? roll) => roll switch
    {
        "2+" => "wfr-2", "3+" => "wfr-3", "4+" => "wfr-4",
        "5+" => "wfr-5", "6+" => "wfr-6", "N/A" => "wfr-na", _ => ""
    };

    private List<Profile> GetAllWeapons(Selection unit)
    {
        var ranged = GetAllProfilesRecursive(unit, "Ranged Weapons");
        var melee  = GetAllProfilesRecursive(unit, "Melee Weapons");
        return ranged.Concat(melee).DistinctBy(w => w.Name).ToList();
    }

    private List<Profile> GetAllProfilesRecursive(Selection? current, string typeName) => RosterHelper.GetAllProfilesRecursive(current, typeName);

    private string GetChar(Profile? p, string statName) => RosterHelper.GetChar(p, statName);

    private void ShowStratagem(StratagemModelWithDetachment strat) => SelectedStratagem = strat;
    private void CloseModal() => SelectedStratagem = null;

    private void ShowUnitDetails(UnitEntry entry) => ModalUnit = entry;
    private void CloseUnitDetails() => ModalUnit = null;

    private void ShowRule(Rule rule) => SelectedRule = rule;
    private void CloseRuleModal() => SelectedRule = null;

    private List<Rule> GetAbilities(Selection unit) => RosterHelper.GetAbilities(unit, filterWeaponKeywords: true);

    private List<string> GetKeywords(Selection unit) => RosterHelper.GetKeywords(unit);

    private static MarkupString FormatText(string text) => RosterHelper.FormatText(text);

    private static string StratClass(StratagemModelWithDetachment s)
    {
        var t = s.Turn.ToLower();
        if (t.Contains("your")) return "strat-blue";
        if (t.Contains("opponent")) return "strat-red";
        return "strat-green";
    }

    private string GetPlayerColor(string playerId) => playerId switch
    {
        "p2" => "#5dade2",
        "p3" => "#2ecc71",
        "p4" => "#a855f7",
        "p5" => "#e74c3c",
        "p6" => "#f39c12",
        _    => "#ffc107"
    };
}


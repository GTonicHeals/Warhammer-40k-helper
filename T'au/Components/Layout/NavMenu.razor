@using System.Text.Json
@using Warhammer.Models
@using Warhammer.Services
@using System.IO
@using System.Text.RegularExpressions
@inject IWebHostEnvironment Env
@inject NavigationManager NavManager
@inject FactionStateService FactionState
@implements IDisposable

<style>
    /* Dynamically overrides the sidebar background based on the current page */
    .sidebar {
        background: linear-gradient(180deg, #2b2b2b 0%, @ActiveGradientColor 100%) !important;
        transition: background 0.5s ease;
    }
</style>

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex align-items-center justify-content-between">
        <a class="navbar-brand" href="">Battle Command</a>
        <button type="button" class="navbar-toggler-btn @(_navOpen ? "active" : "")" @onclick="ToggleNav" aria-label="Toggle navigation">&#9776;</button>
    </div>
</div>

<div class="nav-scrollable @(_navOpen ? "show" : "")" @onclick="CloseNav">
    <nav class="flex-column">

        <!-- Primary Tool -->
        <div class="nav-item px-3 mt-3 mb-1">
            <span class="text-uppercase fw-bold text-white-50 small ps-3">Command Tools</span>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="woundcalc">
                <span class="bi bi-calculator text-warning" aria-hidden="true"></span>
                <span class="fw-bold text-white">Wound Calculator</span>
            </NavLink>
        </div>

        <hr class="border-secondary mx-3 my-2" />

        <!-- Reference Section -->
        <div class="nav-item px-3 mt-3 mb-1">
            <span class="text-uppercase fw-bold text-white-50 small ps-3">Reference</span>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="quickref#turn-sequence">
                <span class="bi bi-journals" aria-hidden="true"></span> Quick Handbook
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="corestratagems">
                <span class="bi bi-lightning-charge" aria-hidden="true"></span> Stratagems
            </NavLink>
        </div>

        @{
            var activeFactionLinks = FactionState.PlayerFactions.Values
                .Select(ResolveFaction)
                .Where(x => x.HasValue)
                .Select(x => x!.Value)
                .DistinctBy(x => x.Route)
                .ToList();
        }
        @foreach (var (route, displayName) in activeFactionLinks)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@route">
                    <span class="bi bi-book" aria-hidden="true"></span> @displayName Rules
                </NavLink>
            </div>
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="scenarios">
                <span class="bi bi-journals" aria-hidden="true"></span> Scenarios
            </NavLink>
        </div>

        @if (Players.Any())
        {
            <div class="nav-item px-3 mt-3 mb-1">
                <span class="text-uppercase fw-bold text-white-50 small ps-3">Tactical Objectives</span>
            </div>

            @foreach (var player in Players)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="@($"objectives/{player.Id}")">
                        <span class="bi bi-person-badge" aria-hidden="true" style="color: @player.Color;"></span> @player.Label
                    </NavLink>
                </div>
            }

            @foreach (var player in Players)
            {
                <div class="player-section mt-3">
                    <div class="nav-item px-3 mb-1">
                        <span class="text-uppercase fw-bold small ps-3" style="letter-spacing: 1px; color: @player.Color;">@player.Label</span>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"roster/{player.Id}")">
                            <span class="bi bi-list-nested" aria-hidden="true" style="color: @player.Color;"></span> Full Roster
                        </NavLink>
                    </div>

                    @foreach (var unit in player.Units.DistinctBy(u => u.Name))
                    {
                        <div class="nav-item px-3">
                            <NavLink class="nav-link py-0" href="@($"roster/{player.Id}#{GetId(unit)}")">
                                <span class="bi bi-chevron-right small me-2" aria-hidden="true" style="color: @player.Color;"></span>
                                <span style="font-size: 0.9em;">@unit.Name</span>
                            </NavLink>
                        </div>
                    }
                </div>
            }
        }
    </nav>
</div>

@code {
    // Ordered list of (keyword, route, display name).
    // catalogueName from BattleScribe is fully-qualified (e.g. "Xenos - T'au Empire"),
    // so we do substring matching rather than exact lookup.
    // Earlier/more-specific entries win when multiple keywords would match.
    private static readonly (string Keyword, string Route, string DisplayName)[] FactionMappings =
    [
        ("Black Templars",   "btrules",       "Black Templars"),
        ("T'au Empire",      "tau-rules",     "T'au Empire"),
        ("Space Marines",    "smrules",       "Space Marines"),
        ("Adeptus Astartes", "smrules",       "Space Marines"),
        ("Necrons",          "necronsrules",  "Necrons"),
        ("Tyranids",         "tyranidsrules", "Tyranids"),
        ("Orks",             "orkrules",      "Orks"),
    ];

    private static (string Route, string DisplayName)? ResolveFaction(string catalogueName)
    {
        foreach (var (keyword, route, display) in FactionMappings)
            if (catalogueName.Contains(keyword, StringComparison.OrdinalIgnoreCase))
                return (route, display);
        return null;
    }

    public class PlayerMenuData
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public string Color { get; set; } = "";
        public List<Selection> Units { get; set; } = new();
    }

    private List<PlayerMenuData> Players = new();
    private Action _onFactionChange = default!;
    private bool _disposed;
    private bool _navOpen = false;

    private void ToggleNav() => _navOpen = !_navOpen;
    private void CloseNav() => _navOpen = false;

    private string ActivePlayerId = "p1";
    private string ActiveGradientColor => GetGradientColor(ActivePlayerId);

    protected override async Task OnInitializedAsync()
    {
        NavManager.LocationChanged += OnLocationChanged;
        UpdateActivePlayer(NavManager.Uri);

        _onFactionChange = async () =>
        {
            if (_disposed) return;
            try { await InvokeAsync(StateHasChanged); }
            catch (ObjectDisposedException) { }
        };
        FactionState.OnChange += _onFactionChange;

        int playerIndex = 1;
        while (true)
        {
            string playerId = $"p{playerIndex}";
            string fileName = $"{playerId}.json";

            var (units, faction) = await LoadPlayerData(fileName);

            if (units == null || !units.Any()) break;

            FactionState.SetFaction(playerId, faction);

            Players.Add(new PlayerMenuData
            {
                Id = playerId,
                Label = $"Player {playerIndex}",
                Color = GetPlayerColor(playerId),
                Units = units
            });

            playerIndex++;
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_disposed) return;
        UpdateActivePlayer(e.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateActivePlayer(string uri)
    {
        var match = Regex.Match(uri, @"/(roster|objectives)/(p\d+)");
        if (match.Success)
            ActivePlayerId = match.Groups[2].Value;
        else
            ActivePlayerId = "p1";
    }

    public void Dispose()
    {
        _disposed = true;
        NavManager.LocationChanged -= OnLocationChanged;
        FactionState.OnChange -= _onFactionChange;
    }

    private async Task<(List<Selection>? units, string faction)> LoadPlayerData(string fileName)
    {
        var filePath = Path.Combine(Env.WebRootPath, fileName);
        if (!File.Exists(filePath)) return (null, "");

        try
        {
            var jsonString = await File.ReadAllTextAsync(filePath);
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var data = JsonSerializer.Deserialize<RosterRoot>(jsonString, options);

            var force = data?.Roster?.Forces?.FirstOrDefault();
            if (force != null)
            {
                var units = force.Selections
                    .Where(s => s.Name != "Configuration" &&
                                s.Name != "Battle Size" &&
                                s.Name != "Detachment" &&
                                s.Name != "Show/Hide Options")
                    .ToList();
                return (units, force.CatalogueName);
            }
        }
        catch { }
        return (null, "");
    }

    private string GetId(Selection unit) => unit.Name?.Replace(" ", "-").Replace("'", "").Replace("'", "") ?? "unknown";

    private string GetPlayerColor(string side) => side switch
    {
        "p2" => "#5dade2",
        "p3" => "#2ecc71",
        "p4" => "#a855f7",
        "p5" => "#e74c3c",
        "p6" => "#f39c12",
        _ => "#ffc107"
    };

    private string GetGradientColor(string side) => side switch
    {
        "p2" => "#154360",
        "p3" => "#145a32",
        "p4" => "#4a235a",
        "p5" => "#641e16",
        "p6" => "#7e5109",
        _ => "darkred"
    };
}
